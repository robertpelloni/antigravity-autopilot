{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"watch"
			],
			"isBackground": true,
			"problemMatcher": {
				"owner": "esbuild",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "^(.+):(\\d+):(\\d+): (error|warning): (.+)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"severity": 4,
					"message": 5
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[watch\\]",
					"endsPattern": "^Done in \\d+ms$|^✘"
				}
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "never"
			}
		},
		{
			"label": "compile",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"compile"
			],
			"isBackground": false,
			"problemMatcher": {
				"owner": "esbuild",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "^(.+):(\\d+):(\\d+): (error|warning): (.+)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"severity": 4,
					"message": 5
				}
			}
		},
		{
			"label": "Recompile VSIX",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"package"
			],
			"isBackground": false
		}
	]
}